# ==================== 应用配置 ====================
APP_NAME=AI Service
API_VERSION=1.0

# ==================== 数据库配置 ====================
# MySQL 数据库连接配置
DATABASE_URL=mysql+aiomysql://{username}:{password}@localhost:3306/ai_service
DATABASE_USERNAME=root
DATABASE_PASSWORD=your_password_here

# ==================== Redis 配置 ====================
REDIS_URL=redis://localhost:6379/0

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_DIR=logs

# ==================== 积分策略配置 ====================
# 月度自动发放积分数量
MONTHLY_GRANT_AMOUNT=100000

# 各服务积分消耗配置
AICHAT_POINTS_COST=100
OCR_GENERAL_POINTS_COST=50
JFBYM_POINTS_COST=10

# 语音服务积分配置
XFYUN_SPEECH_ASR_POINTS_PER_UNIT=10
XFYUN_SPEECH_ASR_SECONDS_PER_UNIT=60
XFYUN_SPEECH_TTS_POINTS_PER_UNIT=10
XFYUN_SPEECH_TTS_CHARS_PER_UNIT=100
XFYUN_SPEECH_POLL_INTERVAL_SECONDS=2.0
XFYUN_SPEECH_POLL_TIMEOUT_SECONDS=300

# ==================== AI 聊天服务配置 ====================
# DeepSeek API 配置
AICHAT_BASE_URL=https://api.deepseek.com/v1
AICHAT_API_KEY=your_deepseek_api_key_here

# ==================== Computer Use API 配置 ====================
CUA_BASE_URL=https://api.anthropic.com/v1
CUA_API_KEY=your_anthropic_api_key_here

# ==================== 讯飞 API 配置 ====================
# 讯飞 OCR 和语音服务配置
XFYUN_APP_ID=your_xfyun_app_id
XFYUN_API_SECRET=your_xfyun_api_secret
XFYUN_API_KEY=your_xfyun_api_key

# 讯飞智能组件 API Key
XFYUN_INTSIG_API_KEY=your_xfyun_intsig_api_key

# ==================== 云码验证码服务配置 ====================
JFBYM_ENDPOINT=http://api.jfbym.com/api/YmServer/customApi
JFBYM_API_TOKEN=your_jfbym_token_here
